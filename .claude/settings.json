{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/build-check.sh\"",
            "timeout": 60,
            "statusMessage": "Verifying build…"
          }
        ]
      }
    ]
  }
}
